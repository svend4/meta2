# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.github/
.gitignore

# ── Python кэш и артефакты ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
htmlcov/
.coverage
coverage.xml
*.stats

